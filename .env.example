# ============================================
# Mapa de Compatibilidade — Variáveis de Ambiente
# ============================================
# Prefixo suportado: NEXT_PUBLIC_* (ou VITE_*)
# Copie este arquivo para .env e ajuste os valores

# Modo da aplicação: production | development
NEXT_PUBLIC_ENV=production

# Habilitar paywall: true | false
NEXT_PUBLIC_PAYWALL=true

# Habilitar ferramentas de desenvolvimento: true | false
NEXT_PUBLIC_DEVTOOLS=false

# URL da API backend (opcional, vazio = sem backend)
VITE_API_URL=
